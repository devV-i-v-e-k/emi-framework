# ============================================================
#  Cloud-Based EMI Failure Prevention Framework
#  Environment Configuration – .env
#  NEVER commit this file to version control!
# ============================================================

# ── Application ───────────────────────────────────────────
SECRET_KEY=change-this-to-a-strong-random-secret-key-256bit
DEBUG=False
PORT=5000

# Session lifetime in seconds (default: 1 hour)
SESSION_LIFETIME=3600

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=*

# ── Database (Local Development) ──────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=emi_user
DB_PASSWORD=emi_password
DB_NAME=emi_framework

# ── Database (AWS RDS Production) ─────────────────────────
# DB_HOST=emi-framework.xxxxxxxx.us-east-1.rds.amazonaws.com
# DB_PORT=3306
# DB_USER=emi_admin
# DB_PASSWORD=<strong-rds-password>
# DB_NAME=emi_framework

# ── Email / SMTP ──────────────────────────────────────────
# Leave blank to run in simulation mode (alerts logged only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@emi-framework.com

# ── AWS Configuration ─────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket for database backups
S3_BACKUP_BUCKET=emi-framework-backups

# CloudWatch log group
CLOUDWATCH_LOG_GROUP=/emi-framework/application
CLOUDWATCH_LOG_STREAM=production
